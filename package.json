{
  "name": "chat-bot-ai-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Admin panel for the chat-bot-ai multi-tenant WhatsApp bot SaaS.",
  "engines": {
    "node": "22.13.1"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=8192 nuxt build",
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 nuxt dev",
    "generate": "NODE_OPTIONS=--max-old-space-size=8192 nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "clean": "rm -rf .nuxt .output node_modules/.cache node_modules/.vite",
    "reinstall": "rm -rf node_modules package-lock.json .nuxt .output && npm install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^9.5.6",
    "@pinia/nuxt": "^0.5.5",
    "nuxt": "3.21.2",
    "pinia": "^2.2.6",
    "three": "^0.185.1",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.6.1",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@types/node": "^22.10.0",
    "@types/three": "^0.185.0",
    "eslint": "^9.14.0",
    "typescript": "^5.6.3",
    "vue-tsc": "^2.1.10"
  }
}
